{
  "info": {
    "_postman_id": "test-create-po-api",
    "name": "VMS - Create PO API Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    if (response.token) {",
              "        pm.collectionVariables.set('auth_token', response.token);",
              "        console.log('Token saved:', response.token);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Create PO",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const response = pm.response.json();",
              "    ",
              "    // Validate response",
              "    pm.test('PO created successfully', () => {",
              "        pm.expect(response.po_number).to.exist;",
              "        pm.expect(response.status).to.eql('Pending');",
              "        pm.expect(response.vendor_status).to.be.null;",
              "        pm.expect(response.line_items).to.be.an('array').that.is.not.empty;",
              "    });",
              "    ",
              "    pm.test('Line items validation', () => {",
              "        const firstItem = response.line_items[0];",
              "        pm.expect(firstItem.product_name).to.exist;",
              "        pm.expect(firstItem.quantity).to.exist;",
              "        pm.expect(firstItem.status).to.eql('Pending');",
              "    });",
              "    ",
              "    console.log('✅ PO Created:', response.po_number);",
              "} else {",
              "    pm.test('PO creation failed', () => {",
              "        pm.expect(pm.response.code).to.eql(201);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"po\": {\n    \"po_number\": \"TEST{{$randomInt}}\",\n    \"vendor_id\": \"3\",\n    \"type\": \"NEW_ITEMS\",\n    \"priority\": \"MEDIUM\",\n    \"po_date\": \"2026-03-03\"\n  },\n  \"line_items\": [\n    {\n      \"product_code\": 1001,\n      \"product_name\": \"Test Product 1\",\n      \"quantity\": 10,\n      \"gst_percent\": 18.0,\n      \"price\": 100.00,\n      \"mrp\": 120.00,\n      \"line_priority\": \"MEDIUM\",\n      \"expected_delivery_date\": \"2026-03-10\"\n    },\n    {\n      \"product_code\": 1002,\n      \"product_name\": \"Test Product 2\",\n      \"quantity\": 5,\n      \"gst_percent\": 18.0,\n      \"price\": 50.00,\n      \"mrp\": 60.00,\n      \"line_priority\": \"LOW\",\n      \"expected_delivery_date\": \"2026-03-15\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/pos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pos"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Get Created PO",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pos/{{poId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pos",
            "{{poId}}"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api/v1/admin"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "poId",
      "value": ""
    }
  ]
}
